INTERVALS_API_KEY=your_api_key_here
ATHLETE_ID=your_athlete_id_here
STANDARD_LIBRARY_ATHLETE_ID=shared_library_athlete_id_here

# Optional: Microsoft Foundry project endpoint, used by foundry-agent scripts
# (deploy_agent.py / invoke_agent.py).
# Format: https://<resource>.services.ai.azure.com/api/projects/<project>
FOUNDRY_PROJECT_ENDPOINT=your_foundry_project_endpoint_here

# Optional: defaults for foundry-agent/invoke_agent.py test runs.
# DISCIPLINE: climber | criterium | marathon | roadrace (default: climber)
# RESPONSE_LANGUAGE: language code for answers (default: de)
# MESSAGE: the user message sent to the agent
DISCIPLINE=climber
RESPONSE_LANGUAGE=de
MESSAGE=Please assess my current training week. Use the MCP tools to fetch data first.

# Optional: public hostname of your Cloudflare tunnel (or other reverse proxy).
# Required when running the MCP server in SSE mode behind a tunnel so the
# server accepts requests with that Host header.
# Leave empty or remove if you are not using a tunnel.
FASTMCP_ALLOWED_HOST=your-tunnel-hostname.example.com
